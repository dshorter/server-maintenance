# rclone config for off-site backup to Backblaze B2.
#
# Install:
#   sudo install -d -m 700 /root/.config/rclone
#   sudo cp /opt/server-maintenance/scripts/rclone.conf.example \
#           /root/.config/rclone/rclone.conf
#   sudo chmod 600 /root/.config/rclone/rclone.conf
#   # then fill in account/key below
#
# Verify after editing:
#   sudo rclone lsd b2:
#   sudo rclone touch b2:<bucket>/_writetest && sudo rclone delete b2:<bucket>/_writetest
#
# The application key must be scoped to ONE bucket, with read+write+DELETE:
# backup.sh prunes old bundles itself (rclone delete --min-age), so
# deleteFiles is required — the wipe-resistance comes from the bucket's
# Object Lock on recent bundles, not from denying delete. What the key must
# NOT have: account-wide scope, writeKeys, deleteBuckets (see
# /opt/_host/README.md §Credentials, corrected 2026-07-03).

[b2]
type = b2
account = REPLACE_WITH_KEY_ID
key     = REPLACE_WITH_APPLICATION_KEY
hard_delete = true
