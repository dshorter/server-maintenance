# Server-maintenance environment variables
# Copy to .env and fill in real values. .env is gitignored.

# ngrok tunnel auth (existing)
NGROK_AUTHTOKEN=

# Postgres for HVAC demo (optional, has default in compose)
POSTGRES_PASSWORD=

# Ghost blog — required if running --profile ghost
# Generate with: openssl rand -base64 24
GHOST_MYSQL_ROOT_PASSWORD=
GHOST_DB_PASSWORD=

# API keys for predictor profile (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
